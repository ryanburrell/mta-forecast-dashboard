# Copy to etl/.env for local runs (python-dotenv loads it automatically via
# run_pipeline.py). In GitHub Actions these are repo secrets instead - never
# commit a real .env file.

# Required only when running with --write-to-supabase:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional - raises the Socrata unauthenticated rate limit (tech-stack doc §10):
MTA_SOCRATA_APP_TOKEN=
